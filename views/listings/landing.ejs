<% layout("/layouts/boilerplate") -%>

<style>
/* Hide search bar specifically on the landing page */
#search-form {
    display: none !important;
}

.landing-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem 0;
}

.landing-hero {
    width: 100%;
    height: 75vh;
    background: url('https://images.unsplash.com/photo-1542314831-c6a4d14d2858?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center center/cover no-repeat;
    border-radius: 1.5rem;
    position: relative;
    overflow: hidden;
    color: white;
    box-shadow: 0 15px 35px rgba(0,0,0,0.15);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
}

.landing-hero-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.45);
    z-index: 1;
}

.landing-hero-content {
    position: relative;
    z-index: 2;
    padding: 0 2rem;
}

.landing-hero-content h1 {
    font-size: 5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    letter-spacing: 2px;
}

.landing-hero-content p {
    font-size: 1.4rem;
    font-weight: 400;
    margin-bottom: 2.5rem;
    text-shadow: 1px 1px 6px rgba(0,0,0,0.5);
}


.btn-explore {
    background-color: #fe424d;
    color: white !important;
    font-size: 1.25rem;
    padding: 0.8rem 3.5rem;
    border-radius: 50px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border: 2px solid #fe424d;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    box-shadow: 0 4px 15px rgba(254, 66, 77, 0.4);
}

.btn-explore:hover {
    background-color: white;
    color: #fe424d !important;
    border-color: white;
    transform: translateY(-4px) scale(1.03);
    box-shadow: 0 10px 25px rgba(254, 66, 77, 0.6);
}

body.dark-mode .landing-hero {
    box-shadow: 0 15px 35px rgba(0,0,0,0.8);
}
body.dark-mode .landing-hero-overlay {
    background: rgba(0,0,0,0.65);
}


@media (max-width: 768px) {
    .landing-hero {
        height: 65vh;
        border-radius: 1rem;
    }
    .landing-hero-content h1 {
        font-size: 3.2rem;
    }
    .landing-hero-content p {
        font-size: 1.1rem;
    }
}
@media (max-width: 480px) {
    .landing-hero-content h1 {
        font-size: 2.5rem;
    }
}
</style>

<div class="landing-wrapper">
    <div class="landing-hero">
        <div class="landing-hero-overlay"></div>
        <div class="landing-hero-content">
            <h1>WANDERLUST</h1>
            <p>"Travel more. Worry less."</p>
            <a href="/listings" class="btn-explore">Explore</a>
        </div>
    </div>
</div>
